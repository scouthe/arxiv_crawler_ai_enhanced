# AI配置示例（推荐本地中台）
# 请将以下内容复制到.env文件中，并替换为您的实际API密钥
# 环境变量优先级：GitHub Secrets >  .env文件
# 使用GitHub Secrets时，会自动覆盖.env文件中的对应配置

# 本地模式可用占位值
OPENAI_API_KEY="vllm-local"

# 官方API基础URL（仅 PROVIDER=official 时使用）
OPENAI_BASE_URL="https://api.deepseek.com"

# 默认模型名称（本地模式需与 /api/models 返回一致）
MODEL_NAME="qwen/Qwen3-14B-FP8"

# 模型提供商: official / local（推荐 local）
PROVIDER="local"

# 本地中台地址（PROVIDER=local 时使用）
# 可填 http://127.0.0.1:8900 或 http://127.0.0.1:8900/v1
MIDPLATFORM_BASE_URL="http://127.0.0.1:8900"

# 本地失败后是否自动切换到云端官方接口（推荐开启）
AUTO_FALLBACK_TO_OFFICIAL=true

# 云端回退配置（仅 PROVIDER=local 且本地失败时使用）
# 兼容别名：CLOUD_OPENAI_BASE_URL / CLOUD_OPENAI_API_KEY / CLOUD_MODEL_NAME
OFFICIAL_OPENAI_BASE_URL=""
OFFICIAL_OPENAI_API_KEY=""
OFFICIAL_MODEL_NAME="deepseek-chat"

# 本地中台分配参数（PROVIDER=local 时使用）
LLM_CTX=8000
LLM_MAX_WAIT_SECONDS=300
LLM_OWNER_ID="arxiv-crawler"

# 默认语言
LANGUAGE="Chinese"

# AI增强的最大并行数
MAX_WORKERS=4

# 爬取模式：true表示全量更新，false表示增量更新
CRAWL_ALL=false

# 指定爬取日期，格式为YYYY-MM-DD，留空表示今天
CRAWL_DATE=""

# 论文分类白名单，使用逗号分隔
CATEGORY_WHITELIST=cs.CV,cs.AI,cs.DS,cs.ET,cs.HC,cs.NE,cs.RO,cs.SD,eess.AS,eess.IV

# 论文分类黑名单，使用逗号分隔
CATEGORY_BLACKLIST=

# 可选关键词，使用逗号分隔
OPTIONAL_KEYWORDS=cs.CV,cs.AI,cs.DS,cs.ET,cs.HC,cs.NE,cs.RO,cs.SD,eess.AS,eess.IV

# 翻译目标语言，留空表示不翻译
TRANS_TO=zh-CN

# 代理设置，格式为http://127.0.0.1:7890，留空表示不使用代理
PROXY=

# 翻译并发限制
TRANSLATION_SEMAPHORE=80

# 每页爬取数量
STEP=50

# 页面访问密码，留空表示不使用密码保护
ACCESS_PASSWORD=

# GitHub提交邮箱，同时作为微信运行总结邮件收件人（可逗号分隔多个）
EMAIL=your-email@example.com

# GitHub提交用户名
NAME=your-github-username

# 微信运行总结邮件（默认开启，缺配置即失败）
WECHAT_ALERT_EMAIL_ENABLED=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_STARTTLS=false
SMTP_FROM=
SMTP_TIMEOUT_SECONDS=15

# Git 同步（必填）
# 现在不再使用 /app 兜底，必须显式设置这两个路径。
GIT_SYNC_SRC_ROOT=/home/heheheh/Documents/n8n/arxiv_crawler_ai_enhanced
GIT_SYNC_REPO_PATH=/home/heheheh/Documents/n8n/arxiv_crawler_ai_enhanced
# 自动 push（可选；不配则只本地 commit）
GIT_USERNAME=
GIT_TOKEN=
GIT_REPO_URL=

# 微信公众号发布配置
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_THUMB_ID_ARXIV_MAIN=
WECHAT_THUMB_ID_ARXIV_AUDIO=
WECHAT_THUMB_ID_ARXIV_HC_RO=
WECHAT_THUMB_ID_JOURNAL=
WECHAT_MARKDOWN_DIR=./to_md/markdown
WECHAT_ASSETS_DIR=./wechat_assets
WECHAT_WAIT_MINUTES=30
WECHAT_WAIT_RETRIES=1
WECHAT_DRAFT_AUTHOR=tianhe
WECHAT_CONTENT_SOURCE_URL=https://scouthe.github.io/arxiv_crawler_ai_enhanced/
WECHAT_TITLE_MAX_BYTES=0

# 微信发布定时服务（不走HTTP）
# 每天 08:00 触发，cron格式: 分 时 日 月 周（目前仅支持固定“分 时”）
WECHAT_SCHEDULE_CRON=0 8 * * *
WECHAT_SCHEDULE_TZ=Asia/Shanghai
# today / yesterday
WECHAT_SCHEDULE_TARGET_DATE=today
# 持久化运行记录目录
WECHAT_RUNS_DIR=./data/wechat_publish_runs
# 调度循环轮询间隔(秒)
WECHAT_SCHEDULER_POLL_SECONDS=20
# 模块开关（true/false）
WECHAT_RUN_ARXIV_MODULE=true
WECHAT_RUN_JOURNAL_MODULE=true
